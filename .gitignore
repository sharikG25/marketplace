# ============================================================
# MARKETPLACE — .gitignore
# Spring Boot + Maven + React + IntelliJ
# ============================================================

# ============================================================
# SEGURIDAD — NUNCA SUBIR
# ============================================================
*.env
.env
.env.local
.env.production
application-prod.properties
application-local.properties
**/src/main/resources/application-secret.properties

# ============================================================
# MAVEN
# ============================================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven wrapper
.mvn/wrapper/maven-wrapper.properties

# ============================================================
# INTELLIJ IDEA
# ============================================================
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ============================================================
# ECLIPSE
# ============================================================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ============================================================
# SPRING BOOT
# ============================================================
spring-shell.log
logs/
*.log
*.log.*

# ============================================================
# REACT / NODE
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.production
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# DOCKER
# ============================================================
docker-compose.override.yml

# ============================================================
# ARCHIVOS TEMPORALES
# ============================================================
*.tmp
*.swp
*.swo
*~
